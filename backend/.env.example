# Use the same Google OAuth web client ID in frontend/.env.
GOOGLE_CLIENT_ID=

# Require a six-digit email code before email/password users can access the app.
EMAIL_VERIFICATION_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USERNAME=your-sender@gmail.com
SMTP_PASSWORD=your-google-app-password
SMTP_FROM_EMAIL=your-sender@gmail.com
SMTP_FROM_NAME=Bambini

# Optional HMAC secret for verification-code hashes. If omitted, SMTP_PASSWORD is used.
# EMAIL_VERIFICATION_SECRET=replace-with-a-long-random-secret

# Comma-separated browser origins used only when frontend and backend run separately.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional. Defaults to backend/app.db.
# DATABASE_URL=sqlite:///C:/absolute/path/to/app.db

# Optional. Defaults to backend/media.
# MEDIA_ROOT=C:/absolute/path/to/media
